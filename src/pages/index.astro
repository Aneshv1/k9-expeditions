---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout title="K9 Expeditions — Dog Training, Boarding & Hiking | Toronto">
  <Navbar />

  <!-- Notice Banner -->
  <section class="bg-k9-green/10 border-b border-k9-green/20 py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm text-neutral-700">
        <strong>Our company name and website has changed!</strong> Visit us at
        <a href="https://www.k9academytraining.ca" target="_blank" class="text-k9-green font-semibold hover:underline">k9academytraining.ca</a>
        for the latest services and pricing.
      </p>
    </div>
  </section>

  <!-- Hero -->
  <section class="bg-neutral-950 py-20 sm:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs tracking-widest uppercase text-k9-green font-semibold mb-4">Toronto's Trusted Dog Specialists</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight">
        Training. Boarding. Hiking.<br />
        <span class="text-k9-green">Built for High-Energy Dogs.</span>
      </h1>
      <p class="mt-6 text-lg text-neutral-400 max-w-2xl mx-auto">
        K9 Expeditions specializes in high-energy and working breeds that need more than typical exercise. Nearly 10 years of trusted service in Toronto.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/free-evaluation" class="inline-flex items-center px-8 py-4 bg-k9-green text-white text-base font-bold rounded-xl hover:bg-k9-green-dark transition-all shadow-lg shadow-k9-green/20">
          Get Your Free Evaluation
        </a>
        <a href="tel:6473767016" class="inline-flex items-center px-8 py-4 border border-white/20 text-white text-base font-semibold rounded-xl hover:bg-white/5 transition-colors">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          647-376-7016
        </a>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs tracking-widest uppercase text-k9-green font-semibold mb-2">What We Do</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">Our Services</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            title: 'Dog Training',
            desc: 'Puppy training, behaviour modification, off-leash training, and Board & Train programs. Immediate results with expert trainers.',
            href: '/training',
            img: '/images/homepage/training-service.jpg',
          },
          {
            title: 'In-Home Boarding',
            desc: 'Safe, structured boarding with 100% supervision. Multiple cameras, crate safety, and daily training sessions included.',
            href: '/boarding',
            img: '/images/homepage/boarding-service.jpg',
          },
          {
            title: 'Hiking Excursions',
            desc: 'Structured trail outings for high-energy dogs. Recall training, social etiquette, and proper mental stimulation on every hike.',
            href: '/rates',
            img: '/images/homepage/hiking-service.jpg',
          },
          {
            title: 'Free Evaluation',
            desc: 'Tell us about your dog and our trainers will review your situation and recommend the best program for your goals.',
            href: '/free-evaluation',
            img: '/images/testimonials/moxie.jpg',
          },
        ].map((service) => (
          <a href={service.href} class="group bg-neutral-50 rounded-2xl overflow-hidden hover:bg-k9-green-light transition-colors border border-neutral-100">
            <img src={service.img} alt={service.title} class="w-full h-48 object-cover" loading="lazy" />
            <div class="p-6">
              <h3 class="text-lg font-bold text-neutral-900 group-hover:text-k9-green transition-colors">{service.title}</h3>
              <p class="mt-2 text-sm text-neutral-600 leading-relaxed">{service.desc}</p>
              <p class="mt-4 text-sm font-semibold text-k9-green">Learn more &rarr;</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why K9X -->
  <section class="py-16 sm:py-24 bg-neutral-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs tracking-widest uppercase text-k9-green font-semibold mb-2">Why K9 Expeditions</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white">What Makes Us Different</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          {
            title: 'Improved Behaviour',
            desc: 'High-energy dogs need structured leadership. We focus on recall training, social etiquette, and trail navigation — behavioural improvements that extend to your home.',
          },
          {
            title: 'Appropriate Activity',
            desc: 'Athletic breeds need activity matching their working nature. Physical exercise, socialization with compatible dogs, and mental stimulation through terrain navigation.',
          },
          {
            title: 'Safe Travel',
            desc: 'An 80-pound unrestrained dog in a 30 mph collision creates approximately 2,400 pounds of force. We use crates, seat belts, or gates for safe transport to trail locations.',
          },
          {
            title: 'Nearly 10 Years Trusted',
            desc: 'We have been trusted for nearly 10 years with dogs rejected by every other boarding facility. Safety and structure are our top priorities.',
          },
          {
            title: 'Working Breed Specialists',
            desc: 'We specialize in high-energy and working breeds — the dogs that need more than a walk around the block or a typical daycare.',
          },
          {
            title: 'Results That Last',
            desc: 'Our training methods produce lasting behavioural changes. Dogs come home calmer, more focused, and better behaved in all environments.',
          },
        ].map((item) => (
          <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
            <h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-neutral-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial Highlight -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs tracking-widest uppercase text-k9-green font-semibold mb-2">Happy Clients</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">See What Our Puppy Parents Have to Say</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            name: 'Claudia Perez',
            dog: 'Tayto',
            text: 'We left Tayto for a week with Anesh and couldn\'t be happier with the service. Tayto came home calmer and better behaved.',
          },
          {
            name: 'Jenny Woods',
            dog: 'Freddy',
            text: 'Anesh is amazing. The only person who can walk my dog off leash. We trust him completely with Freddy.',
          },
          {
            name: 'Mike Erhardt',
            dog: 'Kobe',
            text: 'We have worked with K9 Expeditions for the past 6 years. Consistent results with our high-energy dog. Wouldn\'t trust anyone else.',
          },
        ].map((t) => (
          <div class="bg-neutral-50 rounded-2xl p-6 border border-neutral-100">
            <div class="flex items-center gap-0.5 mb-3">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-sm text-neutral-600 leading-relaxed italic">"{t.text}"</p>
            <p class="mt-3 text-sm font-semibold text-neutral-900">{t.name} <span class="text-neutral-400 font-normal">&middot; {t.dog}</span></p>
          </div>
        ))}
      </div>

      <div class="text-center mt-8">
        <a href="/testimonials" class="inline-flex items-center text-k9-green font-semibold hover:underline">
          Read all testimonials &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Meet the Trainer -->
  <section class="py-16 sm:py-24 bg-neutral-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs tracking-widest uppercase text-k9-green font-semibold mb-2">Meet Our Trainer</p>
      <img src="/images/about/anesh-profile.jpg" alt="Anesh — K9 Expeditions Founder" class="w-32 h-32 rounded-full object-cover mx-auto mb-6 border-4 border-k9-green/20" />
      <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 mb-6">Anesh</h2>
      <p class="text-neutral-600 leading-relaxed">
        Anesh is the founder and head trainer at K9 Expeditions. With nearly a decade of experience working with high-energy and working breeds, he specializes in dogs that other trainers won't take on. Every inquiry is handled personally — because your dog deserves that level of attention.
      </p>
      <div class="mt-8 flex items-center justify-center gap-4">
        <a href="https://www.instagram.com/k9academyto/" target="_blank" rel="noopener" class="text-neutral-400 hover:text-k9-green transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href="https://www.facebook.com/K9expeditions/" target="_blank" rel="noopener" class="text-neutral-400 hover:text-k9-green transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="mailto:info@k9expeditions.com" class="text-neutral-400 hover:text-k9-green transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-20 bg-k9-green">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white">Ready to Get Started?</h2>
      <p class="mt-4 text-lg text-white/80">Fill out our free evaluation form and our trainers will get back to you with a personalized plan.</p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/free-evaluation" class="inline-flex items-center px-8 py-4 bg-white text-k9-green text-base font-bold rounded-xl hover:bg-neutral-100 transition-colors">
          Free Evaluation
        </a>
        <a href="tel:6473767016" class="inline-flex items-center px-8 py-4 border-2 border-white text-white text-base font-semibold rounded-xl hover:bg-white/10 transition-colors">
          Call 647-376-7016
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout title="Free Evaluation | K9 Expeditions — Toronto" description="Fill out our free evaluation form and our trainers will review your dog's needs and recommend the best program.">
  <Navbar />

  <!-- Hero -->
  <section class="bg-neutral-950 py-16 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs tracking-widest uppercase text-k9-green font-semibold mb-4">Free Evaluation</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight">Tell Us About Your Dog</h1>
      <p class="mt-6 text-lg text-neutral-400 max-w-2xl mx-auto">
        Please feel free to connect with us by phone or email if you have any questions, or fill out the form below and we will follow up with you. Thank you for your interest in K9X!
      </p>
    </div>
  </section>

  <!-- Form -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-neutral-50 rounded-2xl p-6 sm:p-10 border border-neutral-100">
        <h2 class="text-xl font-bold text-neutral-900 mb-1">Free Evaluation Form</h2>
        <p class="text-sm text-neutral-400 mb-8">All fields are required unless marked optional.</p>

        <form id="evaluation-form" class="space-y-6">
          <!-- About You -->
          <div>
            <h3 class="text-sm font-bold text-neutral-900 uppercase tracking-wide mb-4">Information About You</h3>
            <div class="space-y-4">
              <div>
                <label for="name" class="block text-sm font-medium text-neutral-700 mb-1">Name</label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition text-sm" placeholder="First & last name" />
              </div>
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="phone" class="block text-sm font-medium text-neutral-700 mb-1">Phone</label>
                  <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition text-sm" placeholder="(647) 555-1234" />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-neutral-700 mb-1">Email Address</label>
                  <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition text-sm" placeholder="you@email.com" />
                </div>
              </div>
              <div>
                <label for="service" class="block text-sm font-medium text-neutral-700 mb-1">Services Interest</label>
                <select id="service" name="service" required class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition bg-white text-sm">
                  <option value="">Select a service</option>
                  <option value="puppy_program">Puppy Program</option>
                  <option value="behaviour_modification">Behaviour Modification</option>
                  <option value="board_and_train">Board and Train</option>
                  <option value="group_training">Group Training</option>
                </select>
              </div>
              <div>
                <label for="referral" class="block text-sm font-medium text-neutral-700 mb-1">Where did you hear about K9X?</label>
                <input type="text" id="referral" name="referral" required class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition text-sm" placeholder="Google, Instagram, referral, etc." />
              </div>
            </div>
          </div>

          <!-- About Your Dog -->
          <div>
            <h3 class="text-sm font-bold text-neutral-900 uppercase tracking-wide mb-4">Information About Your Dog</h3>
            <div class="space-y-4">
              <div class="grid sm:grid-cols-3 gap-4">
                <div>
                  <label for="dog_name" class="block text-sm font-medium text-neutral-700 mb-1">Dog's Name</label>
                  <input type="text" id="dog_name" name="dog_name" required class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition text-sm" placeholder="Name" />
                </div>
                <div>
                  <label for="breed" class="block text-sm font-medium text-neutral-700 mb-1">Breed</label>
                  <input type="text" id="breed" name="breed" required class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition text-sm" placeholder="Breed" />
                </div>
                <div>
                  <label for="age" class="block text-sm font-medium text-neutral-700 mb-1">Age</label>
                  <input type="text" id="age" name="age" required class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition text-sm" placeholder="e.g. 2 years" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 mb-1">Gender</label>
                <div class="flex gap-4">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="gender" value="Male" required class="w-4 h-4 text-k9-green focus:ring-k9-green/30" />
                    <span class="text-sm text-neutral-700">Male</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="gender" value="Female" class="w-4 h-4 text-k9-green focus:ring-k9-green/30" />
                    <span class="text-sm text-neutral-700">Female</span>
                  </label>
                </div>
              </div>
              <div>
                <label for="concern" class="block text-sm font-medium text-neutral-700 mb-1">Main concern with your dog</label>
                <textarea id="concern" name="concern" rows="3" required class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition resize-none text-sm" placeholder="Tell us what you're dealing with..."></textarea>
              </div>
              <div>
                <label for="bite_history" class="block text-sm font-medium text-neutral-700 mb-1">Has your dog ever bitten a human or dog?</label>
                <textarea id="bite_history" name="bite_history" rows="2" required class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition resize-none text-sm" placeholder="Please describe any incidents..."></textarea>
              </div>
              <div>
                <label for="alone" class="block text-sm font-medium text-neutral-700 mb-1">How is your dog when you're out of the house?</label>
                <textarea id="alone" name="alone" rows="2" required class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition resize-none text-sm" placeholder="Destructive, anxious, calm, etc."></textarea>
              </div>
              <div>
                <label for="training_history" class="block text-sm font-medium text-neutral-700 mb-1">Training history</label>
                <textarea id="training_history" name="training_history" rows="2" required class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition resize-none text-sm" placeholder="Previous trainers, classes, programs..."></textarea>
              </div>
            </div>
          </div>

          <button type="submit" id="submit-btn" class="w-full py-4 bg-k9-green text-white text-base font-bold rounded-xl hover:bg-k9-green-dark transition-all shadow-lg shadow-k9-green/20 hover:shadow-xl disabled:opacity-50 disabled:cursor-not-allowed">
            Submit Free Evaluation
          </button>
        </form>

        <!-- Success -->
        <div id="success-message" class="hidden text-center py-8">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-k9-green/10 flex items-center justify-center">
            <svg class="w-8 h-8 text-k9-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-neutral-900 mb-2">Thank you!</h3>
          <p class="text-neutral-500">Thank you for completing our Free Evaluation form. Please be patient while our trainers review your information. We will get back to you promptly with details on the program they best feel will achieve your training goals for your dog.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('evaluation-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('success-message') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch('/api/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: data.name,
          email: data.email,
          phone: data.phone,
          dog_info: `${data.dog_name}, ${data.breed}, ${data.age}, ${data.gender}`,
          service: data.service,
          message: `Concern: ${data.concern}\nBite history: ${data.bite_history}\nAlone: ${data.alone}\nTraining history: ${data.training_history}\nReferral: ${data.referral}`,
        }),
      });

      if (res.ok) {
        form.classList.add('hidden');
        successMsg.classList.remove('hidden');
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Free Evaluation';
      alert('Something went wrong. Please call us at 647-376-7016 instead.');
    }
  });
</script>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout title="K9s in Action | K9 Expeditions — Toronto" description="See our dogs on the trails, in training sessions, and enjoying their adventures with K9 Expeditions.">
  <Navbar />

  <section class="bg-neutral-950 py-20 sm:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs tracking-widest uppercase text-k9-green font-semibold mb-4">K9s in Action</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight">Our Dogs on the Trail</h1>
      <p class="mt-6 text-lg text-neutral-400">Follow us on Instagram to see daily photos and videos of our pack adventures.</p>
    </div>
  </section>

  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="bg-neutral-50 rounded-2xl p-10 border border-neutral-100">
        <div class="w-16 h-16 mx-auto mb-6 bg-gradient-to-br from-purple-500 via-pink-500 to-orange-500 rounded-2xl flex items-center justify-center">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </div>
        <h2 class="text-2xl font-bold text-neutral-900 mb-3">Follow @k9academyto</h2>
        <p class="text-neutral-600 text-sm leading-relaxed mb-6">
          Check out our Instagram for daily hiking photos, training videos, and behind-the-scenes content from trail adventures across the GTA.
        </p>
        <a href="https://www.instagram.com/k9academyto/" target="_blank" rel="noopener" class="inline-flex items-center px-6 py-3 bg-k9-green text-white text-sm font-bold rounded-xl hover:bg-k9-green-dark transition-colors">
          View on Instagram
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
